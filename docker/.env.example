# docker/.env — values for docker-compose.yml
# Copy to docker/.env and fill in. This file is gitignored.

# Timezone (used by cron and skill log timestamps)
TZ=Europe/Zurich

# The Obsidian Sync remote vault to track
# (find names with: docker compose run --rm anker-mini ob sync-list-remote)
VAULT_NAME="My Vault"

# Where the synced vault lives on the host.
# Bind-mount: you can browse the same files in Finder/Files Explorer.
# Use a relative path next to docker-compose.yml, or an absolute one.
VAULT_HOST_PATH=./vault-data
