# anker-mini — local secrets (gitignored)

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to talk to the bot
TELEGRAM_ALLOWED_USERS=

# Where to look for skills (colon-separated absolute paths)
SKILL_PATHS=/Users/jochen/.claude/skills:/Users/jochen/Nextcloud/ai operator bootcamp 06/x/AI_Assistant/Skills

# Working directory for claude -p invocations (so CLAUDE.md + skills resolve)
CLAUDE_CWD=/Users/jochen/Nextcloud/ai operator bootcamp 06

# Path to claude CLI
CLAUDE_BIN=/usr/local/bin/claude

# Log directory
LOG_DIR=/Users/jochen/Library/Logs/anker-mini
