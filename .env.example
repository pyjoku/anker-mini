# anker-mini — local secrets (gitignored)
#
# On first run, values from this file are migrated into ~/.ankermini/config.json
# (which becomes the canonical config from then on). Keep this file as a
# template only — never commit real values.

# Telegram bot — get a token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the bot
# (find your own ID via @userinfobot). Leave empty during dev only.
TELEGRAM_ALLOWED_USERS=

# Where to look for skills (colon-separated absolute paths)
# Examples:
#   SKILL_PATHS=~/.claude/skills
#   SKILL_PATHS=~/.claude/skills:~/Documents/MyVault/AIOS/Skills
SKILL_PATHS=

# Working directory for `claude -p` invocations (where CLAUDE.md lives)
CLAUDE_CWD=

# Path to the claude CLI (auto-detected from PATH if left blank)
CLAUDE_BIN=claude

# Where skill logs go (default: ~/Library/Logs/anker-mini on macOS,
# ~/.ankermini/logs/ elsewhere)
LOG_DIR=
